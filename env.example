# ═══════════════════════════════════════════════════════════════
#  DAIOS — конфигурация окружения
#  Скопируй в local.env для локальной разработки
# ═══════════════════════════════════════════════════════════════

# ── App ─────────────────────────────────────────────────────────
APP_ENV=development

# ── Названия контейнеров ────────────────────────────────────────
DB_HOST=daios_db
REDIS_HOST=daios_redis
MINIO_HOST=daios_minio
CONTAINER_API=daios_api
CONTAINER_BOT=daios_bot
CONTAINER_SCHEDULER=daios_scheduler
CONTAINER_FRONTEND=daios_frontend

# ── Хосты (имена контейнеров — Docker резолвит их в сети) ───────
DB_HOST=daios_db
DB_PORT=5432
REDIS_HOST=daios_redis
REDIS_PORT=6379

# ── Порты (проброс на хост) ──────────────────────────────────────
PORT_API=8000
PORT_DB=5432
PORT_REDIS=6379
PORT_MINIO_API=9000
PORT_MINIO_CONSOLE=9001
PORT_FRONTEND=3000

# ── PostgreSQL ──────────────────────────────────────────────────
POSTGRES_DB=daios
POSTGRES_USER=daios
POSTGRES_PASSWORD=daios_secret

# ── Minio ───────────────────────────────────────────────────────
MINIO_ROOT_USER=daios_minio
MINIO_ROOT_PASSWORD=daios_minio_secret
MINIO_ENDPOINT=daios_minio:9000
MINIO_ACCESS_KEY=daios_minio
MINIO_SECRET_KEY=daios_minio_secret
MINIO_BUCKET_MEDIA=daios-media
MINIO_SECURE=false

# ── Telegram ────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_USER_ID=your_telegram_user_id

# ── OpenAI ──────────────────────────────────────────────────────
OPENAI_API_KEY=your_openai_key_here
OPENAI_MODEL=gpt-4o-mini

# ── Google Sheets ───────────────────────────────────────────────
GOOGLE_CREDENTIALS_FILE=secrets/google_credentials.json
GOOGLE_SHEETS_WORKOUT_ID=your_spreadsheet_id_here

# ── OpenWeatherMap ──────────────────────────────────────────────
OPENWEATHER_API_KEY=your_key_here
OPENWEATHER_CITY=Almaty

# ── Bus schedule ────────────────────────────────────────────────
BUS_SCHEDULE_URL=https://your-bus-schedule-page.com
