# ── App ─────────────────────────────────────────────────────────
APP_ENV=development

# ── Названия контейнеров ────────────────────────────────────────

CONTAINER_API=daios-api
CONTAINER_BOT=daios-bot
CONTAINER_SCHEDULER=daios-scheduler
CONTAINER_LOGBOT=daios-logbot
CONTAINER_FRONTEND=daios-frontend

# ── Хосты (имена контейнеров — Docker резолвит их в сети) ───────
DB_HOST=daios-db
DB_PORT=5432
REDIS_HOST=daios-redis
REDIS_PORT=6379

# ── Порты (проброс на хост) ──────────────────────────────────────
PORT_API=8000
PORT_DB=5432
PORT_REDIS=6379
PORT_FRONTEND=3000

# ── Frontend → Backend (внутри Docker-сети) ─────────────────────
API_URL=http://daios-api:8000

# ── PostgreSQL ──────────────────────────────────────────────────
POSTGRES_DB=daios
POSTGRES_USER=daios
POSTGRES_PASSWORD=daios_secret

# ── Telegram ────────────────────────────────────────────────────
# Бот: https://t.me/BotFather → /newbot
# User ID: https://t.me/userinfobot
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_USER_ID=your_telegram_user_id
# Отдельный бот для логов (свой токен от @BotFather). Оставь пустым, если не используешь.
TELEGRAM_LOGBOT_TOKEN=
# Куда слать алерты об ошибках. 0 = тот же чат, что TELEGRAM_USER_ID.
TELEGRAM_LOGBOT_CHAT_ID=0
LOG_PUSH_POLL_SECONDS=10

# ── LLM (OpenRouter) ────────────────────────────────────────────
# https://openrouter.ai/keys
OPENAI_API_KEY=your_openrouter_key_here
OPENAI_BASE_URL=https://openrouter.ai/api/v1
MODEL_ORCHESTRATOR=mistralai/mistral-7b-instruct
MODEL_AGENTS=mistralai/mistral-7b-instruct
MODEL_SUMMARY=mistralai/mistral-7b-instruct

# ── Google Sheets ───────────────────────────────────────────────
# Service account: https://console.cloud.google.com/apis/credentials
# Включить API: https://console.cloud.google.com/apis/library/sheets.googleapis.com
# GOOGLE_SHEETS_WORKOUT_ID — берётся из URL таблицы: docs.google.com/spreadsheets/d/{ID}/edit
GOOGLE_CREDENTIALS_FILE=secrets/google_credentials.json
GOOGLE_SHEETS_WORKOUT_ID=your_spreadsheet_id_here

# ── OpenWeatherMap ──────────────────────────────────────────────
# https://home.openweathermap.org/api_keys (бесплатно, 1000 req/день)
OPENWEATHER_API_KEY=your_key_here
OPENWEATHER_CITY=Almaty

# ── Bus schedule ────────────────────────────────────────────────
# URL страницы с расписанием автобусов (парсится напрямую)
BUS_SCHEDULE_URL=https://your-bus-schedule-page.com

# ── YouTube Data API v3 ─────────────────────────────────────────
# https://console.cloud.google.com/apis/credentials
# Включить API: https://console.cloud.google.com/apis/library/youtube.googleapis.com
# Бесплатно: 10 000 units/день (1 search = 100 units → 100 запросов/день)
YOUTUBE_API_KEY=your_youtube_api_key_here

# ── VKontakte API ───────────────────────────────────────────────
# https://vk.com/apps → создать Standalone-приложение → Сервисный ключ
# Метод video.search требует scope=video
VK_ACCESS_TOKEN=your_vk_service_token_here

# ── NewsAPI ─────────────────────────────────────────────────────
# https://newsapi.org/register (бесплатно: 100 req/день, только для разработки)
# Платный план нужен для продакшена: https://newsapi.org/pricing
NEWS_API_KEY=your_newsapi_key_here

JWT_SECRET_KEY=your secret key
                                                                                                                                                                           
ADMIN_EMAIL=your@email.com
ADMIN_PASSWORD=your_secret_password
ADMIN_NAME=Admin